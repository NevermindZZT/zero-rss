# ===========================================
# zero-rss 配置
# ===========================================

# 认证 Token (必须修改!)
AUTH_TOKEN=your-secret-token-here

# 数据库路径 (容器内)
DATABASE_URL=sqlite+aiosqlite:///data/rss.db

# 用户脚本目录
SCRIPTS_DIR=/app/scripts

# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 服务器配置
HOST=0.0.0.0
PORT=11080
APP_VERSION=1.1.0

# 外部访问地址 (用于生成 RSS 订阅链接)
# 留空自动使用 http://127.0.0.1:PORT
# 例如配置域名: https://rss.example.com
EXTERNAL_URL=

# 默认脚本超时 (秒)
SCRIPT_TIMEOUT=60
